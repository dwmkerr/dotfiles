{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git clone:*)",
      "Bash(git fetch:*)",
      "Bash(gh issue view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(gh pr create:*)",
      "Bash(gh search:*)",
      "Grep",
      "Glob",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(brew info:*)",
      "Bash(CLAUDECODE=\"\" command claude --help)",
      "Bash(lms search:*)",
      "Bash(~/.lmstudio/bin/lms search:*)",
      "Bash(~/.lmstudio/bin/lms:*)",
      "WebFetch",
      "WebSearch",
      "Skill(toolkit:claude-code-statusline-development)",
      "mcp__shellwright__shell_start",
      "mcp__shellwright__shell_send",
      "mcp__shellwright__shell_read",
      "mcp__shellwright__shell_screenshot",
      "mcp__shellwright__shell_stop",
      "mcp__shellwright__shell_record_start",
      "mcp__shellwright__shell_record_stop",
      "mcp__notion__notion-search",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-get-comments",
      "mcp__notion__notion-get-teams",
      "mcp__notion__notion-get-users"
    ],
    "additionalDirectories": [
      "~/repos"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-notify.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-notify.sh clear"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "context-engineering-fundamentals@context-engineering-marketplace": true,
    "ark@agents-at-scale-ark": true,
    "toolkit@claude-toolkit": true,
    "ai26@ai26": true,
    "document-skills@anthropic-agent-skills": true,
    "dwmkerr@claude-toolkit": true,
    "superpowers@claude-plugins-official": true,
    "cx@ccp": true,
    "ps@pspipe": true,
    "protocols@claude-toolkit": true,
    "gopls-lsp@claude-plugins-official": true,
    "git-workforest@git-workforest": true,
    "caveman@caveman": true,
    "dwmkerr-toolkit@dwmkerr-claude-toolkit": true
  },
  "extraKnownMarketplaces": {
    "git-workforest": {
      "source": {
        "source": "github",
        "repo": "dwmkerr/git-workforest"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-toolkit": {
      "source": {
        "source": "github",
        "repo": "dwmkerr/claude-toolkit"
      }
    },
    "context-engineering-marketplace": {
      "source": {
        "source": "github",
        "repo": "NeoLabHQ/context-engineering-kit"
      }
    },
    "agents-at-scale-ark": {
      "source": {
        "source": "github",
        "repo": "mckinsey/agents-at-scale-ark"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "ccp": {
      "source": {
        "source": "github",
        "repo": "syzygyhack/ccp"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "dwmkerr-claude-toolkit": {
      "source": {
        "source": "github",
        "repo": "dwmkerr/dwmkerr-claude-toolkit"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
